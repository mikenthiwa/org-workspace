{
  "name": "my-org-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:example-app": "ng serve --project=example-app",
    "build": "ng build --project=example-app --verbose",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "format:test": "prettier --list-different \"./projects/**/*.{ts,html,scss,json}\"",
    "format:write": "prettier --write \"./projects/**/*.{ts,html,scss,json}\"",
    "analyze": "ng build --project=example-app --stats-json --output-hashing=none --named-chunks && esbuild-visualizer --template treemap --metadata dist/example-app/stats.json --filename dist/example-app/analyse/index.html  && http-server -o -c-1 ./dist/example-app/analyse/",
    "analyze:sme": "ng build --project=example-app --source-map --output-hashing=none --named-chunks && source-map-explorer dist/example-app/browser/*.js --html dist/example-app/sme/index.html && http-server -o -c-1 ./dist/example-app/sme/",
    "analyze:deps": "npm-run-all analyze:deps:*",
    "analyze:deps:all": "madge projects/example-app/src/main.ts --ts-config tsconfig.json --image ./deps/example-app/_all.png",
    "analyze:deps:ui": "madge  --extensions ts --ts-config tsconfig.json --image ./deps/example-app/ui.png projects/example-app/src/app/ui/",
    "lint": "ng lint",
    "serve:ssr:example-app": "node --import @angular-architects/native-federation/node-preload dist/example-app/server/server.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/native-federation": "^22.0.2",
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.1",
    "@angular/material-moment-adapter": "^22.0.1",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@softarc/native-federation-orchestrator": "^4.2.2",
    "cors": "^2.8.5",
    "es-module-shims": "^2.8.0",
    "express": "^5.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@softarc/native-federation-orchestrator": "^4.2.2",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.18.0",
    "angular-eslint": "22.0.0",
    "esbuild-visualizer": "^0.6.0",
    "eslint": "^9.28.0",
    "eslint-import-resolver-typescript": "^3.7.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "http-server": "^14.1.1",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.4.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "madge": "^8.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "3.4.2",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.16",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.33.1"
  }
}
